# ==============================================================
# multi-agent-job-engine — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
# ==============================================================

# --- LLM Provider ---
# Options: "openai" (cloud, better quality) or "ollama" (local, zero cost)
LLM_PROVIDER=openai

# --- OpenAI (required if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (required if LLM_PROVIDER=ollama) ---
# Install: https://ollama.com  →  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Tavily Web Search (required for Job Scout agent) ---
# Free tier: https://tavily.com  →  1000 searches/month
TAVILY_API_KEY=tvly-your-key-here

# --- Qdrant Vector DB ---
# Runs via docker compose — no key needed, just host/port
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=job_matching

# --- App Settings ---
LOG_LEVEL=INFO